# ─── cloud-dev shell additions ────────────────────────────────────
# Append to ~/.bashrc on the VM
# Also append tunnel() and its dependencies to ~/.zshrc on local machine

# ─── VM aliases ───────────────────────────────────────────────────

# List all project tmux sessions
alias projects='tmux ls'

# Attach to a project session
go() { tmux attach -t "$1"; }

# Switch Remote Control focus to a project
# Usage: rc todolisto
rc() {
  tmux send-keys -t "$1:main.0" C-c ""
  sleep 1
  tmux send-keys -t "$1:main.0" "claude remote-control --spawn=same-dir --dangerously-skip-permissions" Enter
  sleep 3
  tmux send-keys -t "$1:main.0" "y" Enter
  echo "Remote Control now pointing at: $1"
}

# Clone a repo and spin up its tmux session in one command
# Usage: newproject <org>/<repo> <folder>
# Example: newproject velais-ai-solutions/client-abc velais/client
newproject() {
  local repo=$1
  local folder=$2
  local name=$(basename "$repo")
  local path="$HOME/projects/$folder/$name"

  git clone "git@github.com:$repo.git" "$path"

  # Add to start-projects.sh automatically
  sed -i "/^)/i\\  \"$name:$path\"" ~/start-projects.sh

  # Create tmux session
  tmux new-session -d -s "$name" -c "$path" -x 220 -y 50
  tmux rename-window -t "$name" "main"
  tmux split-window -t "$name:main" -v -l 10 -c "$path"
  tmux split-window -t "$name:main.1" -h -c "$path"
  tmux select-pane -t "$name:main.0" -T "claude"
  tmux select-pane -t "$name:main.1" -T "frontend"
  tmux select-pane -t "$name:main.2" -T "backend"
  tmux send-keys -t "$name:main.0" "claude remote-control --spawn=same-dir --dangerously-skip-permissions" Enter
  sleep 3
  tmux send-keys -t "$name:main.0" "y" Enter
  tmux send-keys -t "$name:main.1" "" ""
  tmux send-keys -t "$name:main.2" "" ""

  echo "✓ $name is ready. Run: rc $name"
}

# ─── Local machine additions (add to ~/.zshrc) ────────────────────

# SSH tunnel to forward a VM port to localhost
# Usage: tunnel 5173
tunnel() {
  ssh -L ${1}:localhost:${1} -N cloud-dev
}
