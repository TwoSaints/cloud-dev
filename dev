#!/usr/bin/env bash
# ═══════════════════════════════════════════════════════════════════
# dev — Local entrypoint for cloud-dev remote development
# ═══════════════════════════════════════════════════════════════════
#
# Opens terminal sessions connected to tmux sessions on the VM.
# Works on Windows 10+ (Windows Terminal + Git Bash) and macOS
# (iTerm2 / Terminal.app).
#
# Usage:
#   dev                       Interactive session picker
#   dev <name>                Attach to a specific session
#   dev ls                    List active sessions on the VM
#   dev open [names...]       Open sessions as tabs (all if no names)
#   dev open -g [names...]    Open sessions in a tiled grid
#   dev tunnel <port> [...]   Forward port(s) from VM to localhost
#   dev help                  Show this help
#
# Once attached, each tmux session has:
#   Ctrl+B 0  claude      Ctrl+B 2  frontend (if configured)
#   Ctrl+B 1  shell       Ctrl+B 3  backend  (if configured)
#   Ctrl+B D  detach
#
# Install:
#   Windows:  copy to ~/bin/ (add to PATH) or source as alias
#   macOS:    cp dev /usr/local/bin/dev && chmod +x /usr/local/bin/dev
#
# ═══════════════════════════════════════════════════════════════════

set -euo pipefail

SSH_HOST="cloud-dev"

# ── Helpers ──────────────────────────────────────────────────────

die() { echo "✗ $*" >&2; exit 1; }

detect_os() {
  case "$(uname -s)" in
    MINGW*|MSYS*|CYGWIN*) echo "windows" ;;
    Darwin)               echo "macos" ;;
    *)                    echo "linux" ;;
  esac
}

OS=$(detect_os)

# On Windows, Git Bash's SSH can't reach the Windows SSH agent named pipe.
# Use the Windows OpenSSH binaries directly.
if [ "$OS" = "windows" ]; then
  SSH_CMD="/c/Windows/System32/OpenSSH/ssh.exe"
  # Native Windows path for use in wt.exe subprocesses (which don't understand /c/ paths)
  SSH_CMD_WIN="C:\\Windows\\System32\\OpenSSH\\ssh.exe"
else
  SSH_CMD="ssh"
  SSH_CMD_WIN=""
fi

get_sessions() {
  $SSH_CMD -o ConnectTimeout=5 -o BatchMode=yes "$SSH_HOST" \
    "tmux ls -F '#{session_name}'" 2>/dev/null || true
}

# Get session names with their group colors (format: "name:color" per line)
get_session_meta() {
  $SSH_CMD -o ConnectTimeout=5 -o BatchMode=yes "$SSH_HOST" \
    'for s in $(tmux ls -F "#{session_name}"); do
      color=$(tmux show -t "$s" -v @color 2>/dev/null)
      echo "$s:${color:-#c8a96e}"
    done' 2>/dev/null || true
}

# Group display order (consistent tab/pane positioning)
GROUP_ORDER=("velais" "personal" "m2" "system")

# Group → scheme name lookup (bash 3.2 compatible)
_group_scheme() {
  case "$1" in
    velais)   echo "Terra-Velais" ;;
    personal) echo "Terra-Personal" ;;
    m2)       echo "Terra-M2" ;;
    system)   echo "Terra-System" ;;
    *)        echo "Terra" ;;
  esac
}

# Reverse lookup: color hex → group name
_color_to_group() {
  case "$1" in
    "#6b9bc0") echo "velais" ;;
    "#7a8c5e") echo "personal" ;;
    "#c8a96e") echo "m2" ;;
    "#917068") echo "system" ;;
    *)         echo "system" ;;
  esac
}

# Lookup session color from _SESSION_META (bash 3.2 compatible)
_SESSION_META=""
_session_color() {
  local result
  result=$(echo "$_SESSION_META" | grep "^${1}:" | head -1 | cut -d: -f2)
  echo "${result:-#c8a96e}"
}

# Lookup session group from _SESSION_META
_session_group() {
  _color_to_group "$(_session_color "$1")"
}

# Sort session names by group order
_sort_sessions() {
  local meta="$1"
  for group in "${GROUP_ORDER[@]}"; do
    while IFS=: read -r name color; do
      [ -z "$name" ] && continue
      local g=$(_color_to_group "$color")
      [ "$g" = "$group" ] && echo "$name"
    done <<< "$meta"
  done
}

# Resolve session list: specific names if given, otherwise all
resolve_sessions() {
  local sessions_raw
  sessions_raw=$(get_sessions)
  [ -z "$sessions_raw" ] && die "No sessions running on $SSH_HOST"

  if [ $# -gt 0 ]; then
    # Validate requested names exist
    for name in "$@"; do
      echo "$sessions_raw" | grep -qx "$name" \
        || die "Session '$name' not found. Run: dev ls"
    done
    printf '%s\n' "$@"
  else
    echo "$sessions_raw"
  fi
}

# ── Commands ─────────────────────────────────────────────────────

cmd_help() {
  cat << 'EOF'
dev — cloud-dev remote development

Sessions:
  dev                       Pick a session interactively
  dev <name>                Attach to a session
  dev ls                    List sessions (grouped by org)
  dev open                  Open all sessions as tabs
  dev open -g               Open all sessions in a tiled grid
  dev open <n1> <n2> ...    Open specific sessions only
  dev open -g <n1> <n2>     Grid with specific sessions only
  dev tunnel <port> [...]   Forward port(s) to localhost

GSD workflow:
  dev plan                  Batch discussions — answer planning questions
  dev launch                Start autonomous execution queue
  dev status                Show queue progress
  dev verify                Batch review completed work
  dev priority <repos...>   Set execution priority order
  dev idea <repo> "text"    Capture a feature idea for a repo
  dev ideas start           Start the idea listener (captures from phone)

Inside a session:
  Ctrl+B 0        main window (claude + servers)
  Ctrl+B 1        shell (git, manual commands)
  Ctrl+B D        detach (session keeps running)
  Ctrl+B [        copy mode (scroll with j/k, Ctrl+U/D)
  Alt+Shift+P     zoom/unzoom pane (grid mode)

Typical workflow:
  dev plan        → do all discussions in one sitting
  dev launch      → Claude executes autonomously (queue managed)
  dev status      → check progress anytime
  dev verify      → review completed work when ready

Adding a repo (on the VM):
  newproject <org>/<repo> <folder>
  Sessions auto-appear in dev commands on next run.

Removing a repo (on the VM):
  tmux kill-session -t <name>
  Then remove its entry from ~/start-projects.sh
EOF
}

cmd_ls() {
  local meta
  meta=$(get_session_meta)
  [ -z "$meta" ] && die "No sessions running on $SSH_HOST"

  # Group sessions by their color (which maps to org)
  echo "Sessions on $SSH_HOST:"
  echo ""

  local current_group=""
  # Sort by color to group them, then display
  echo "$meta" | sort -t: -k2 | while IFS=: read -r name color; do
    if [ "$color" != "$current_group" ]; then
      current_group="$color"
      # Reverse-lookup group name from color
      local group="other"
      case "$color" in
        "#6b9bc0") group="velais" ;;
        "#7a8c5e") group="personal" ;;
        "#c8a96e") group="m2" ;;
        "#917068") group="system" ;;
      esac
      echo "  [$group]"
    fi
    echo "    $name"
  done
  echo ""
}

cmd_attach() {
  exec $SSH_CMD "$SSH_HOST" -t "tmux select-window -t '$1':main 2>/dev/null || true && tmux attach -t '$1'"
}

cmd_tunnel() {
  [ $# -eq 0 ] && die "Usage: dev tunnel <port> [port...]"
  local args=""
  for port in "$@"; do
    args="$args -L ${port}:localhost:${port}"
  done
  echo "Tunnelling [$*] → localhost  (Ctrl+C to stop)"
  # shellcheck disable=SC2086
  exec $SSH_CMD $args -N "$SSH_HOST"
}

cmd_pick() {
  local sessions=("$@")
  local n=${#sessions[@]}

  echo "Sessions on $SSH_HOST:"
  echo ""
  for ((i = 0; i < n; i++)); do
    echo "  $((i + 1))) ${sessions[$i]}"
  done
  echo ""
  read -rp "Attach to (1-$n): " choice

  if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le "$n" ]; then
    cmd_attach "${sessions[$((choice - 1))]}"
  else
    die "Invalid choice"
  fi
}

# ── Windows Terminal: tabs ───────────────────────────────────────

# Stagger interval (seconds) between SSH connections.
# Without staggering, simultaneous SSH handshakes through the
# 1Password agent pipe overwhelm Windows Terminal and cause hangs.
WT_STAGGER=2

wt_tabs() {
  local sessions=("$@")

  # First tab creates the window
  local s="${sessions[0]}"
  local color="$(_session_color "$s")"
  wt.exe --title "$s" --tabColor "$color" "$SSH_CMD_WIN" "$SSH_HOST" -t "tmux select-window -t $s:main 2>/dev/null || true && tmux attach -t $s"

  # Add remaining tabs with staggered delay
  for ((i = 1; i < ${#sessions[@]}; i++)); do
    sleep $WT_STAGGER
    s="${sessions[$i]}"
    color="$(_session_color "$s")"
    wt.exe -w 0 new-tab --title "$s" --tabColor "$color" "$SSH_CMD_WIN" "$SSH_HOST" -t "tmux select-window -t $s:main 2>/dev/null || true && tmux attach -t $s"
  done

  echo "✓ Opened ${#sessions[@]} tabs in Windows Terminal"
}

# ── Windows Terminal: grid ───────────────────────────────────────
#
# Max 3 rows per column. Adds columns as needed.
# Uses sequential wt.exe calls with sleep to stagger SSH connections.
#
#   3 sessions:  s1 | s2     6 sessions:  s1 | s4    7 sessions:  s1 | s4 | s6
#                s2 | s3                  s2 | s5                 s2 | s5 | s7
#                                         s3 | s6                 s3 |    |

_split_frac() {
  local k=$1 i=$2
  awk "BEGIN { printf \"%.2f\", ($k - 1 - $i) / ($k - $i) }"
}

wt_grid() {
  local sessions=("$@")
  local n=${#sessions[@]}

  [ "$n" -eq 1 ] && { wt_tabs "${sessions[@]}"; return; }
  [ "$n" -gt 12 ] && {
    echo "⚠ Grid supports up to 12 sessions. Opening as tabs instead."
    wt_tabs "${sessions[@]}"
    return
  }

  _scheme_for() {
    local group="$(_session_group "$1")"
    echo "$(_group_scheme "$group")"
  }

  # Distribute sessions into columns (max 3 rows each)
  local max_rows=3
  local num_cols=$(( (n + max_rows - 1) / max_rows ))
  local col_starts=()
  local col_sizes=()
  local idx=0
  for ((c = 0; c < num_cols; c++)); do
    col_starts+=("$idx")
    local remaining=$((n - idx))
    local remaining_cols=$((num_cols - c))
    local col_size=$(( (remaining + remaining_cols - 1) / remaining_cols ))
    col_sizes+=("$col_size")
    idx=$((idx + col_size))
  done

  # ── Step 1: Create first pane (col 0, row 0) ──────────────────
  local s="${sessions[0]}"
  local scheme=$(_scheme_for "$s")
  wt.exe --title "$s" --colorScheme "$scheme" "$SSH_CMD_WIN" "$SSH_HOST" -t "tmux select-window -t $s:main 2>/dev/null || true && tmux attach -t $s"

  # ── Step 2: Create remaining columns (split right) ────────────
  # After this, each column is one pane. Focus ends on last column.
  for ((c = 1; c < num_cols; c++)); do
    sleep $WT_STAGGER
    local ci="${col_starts[$c]}"
    s="${sessions[$ci]}"
    scheme=$(_scheme_for "$s")
    local frac
    frac=$(_split_frac "$num_cols" "$((c - 1))")
    wt.exe -w 0 sp -V -s "$frac" --title "$s" --colorScheme "$scheme" "$SSH_CMD_WIN" "$SSH_HOST" -t "tmux select-window -t $s:main 2>/dev/null || true && tmux attach -t $s"
  done

  # ── Step 3: Split each column into rows (right to left) ───────
  # Process right-to-left: each unsplit column to the left is still
  # a single pane, so move-focus left always lands correctly.
  for ((c = num_cols - 1; c >= 0; c--)); do
    local csize="${col_sizes[$c]}"
    local ci="${col_starts[$c]}"

    [ "$csize" -le 1 ] && continue

    # Move focus left to reach this column (1 move per column gap)
    if [ "$c" -lt $((num_cols - 1)) ]; then
      wt.exe -w 0 mf left
    fi

    # Split this column into rows
    for ((r = 1; r < csize; r++)); do
      sleep $WT_STAGGER
      s="${sessions[$((ci + r))]}"
      scheme=$(_scheme_for "$s")
      local frac
      frac=$(_split_frac "$csize" "$((r - 1))")
      wt.exe -w 0 sp -H -s "$frac" --title "$s" --colorScheme "$scheme" "$SSH_CMD_WIN" "$SSH_HOST" -t "tmux select-window -t $s:main 2>/dev/null || true && tmux attach -t $s"
    done
  done

  echo "✓ Opened $n sessions in grid ($num_cols columns)"
  echo ""
  echo "  Alt+Arrow        move between panes"
  echo "  Alt+Shift+Arrow  resize panes"
}

# ── macOS: tabs ──────────────────────────────────────────────────

mac_tabs() {
  local sessions=("$@")

  if [ -d "/Applications/iTerm.app" ]; then
    _iterm_tabs "${sessions[@]}"
  else
    _terminal_tabs "${sessions[@]}"
  fi
}

_iterm_profile_for() {
  local group="$(_session_group "$1")"
  echo "$(_group_scheme "$group")"
}

_iterm_tabs() {
  local sessions=("$@")
  local cmds=""
  local first_profile=$(_iterm_profile_for "${sessions[0]}")

  for ((i = 0; i < ${#sessions[@]}; i++)); do
    local s="${sessions[$i]}"
    local profile=$(_iterm_profile_for "$s")
    if [ "$i" -eq 0 ]; then
      cmds="$cmds
    tell current session of current tab
      write text \"$SSH_CMD $SSH_HOST -t 'tmux select-window -t $s:main 2>/dev/null || true && tmux attach -t $s'\"
    end tell"
    else
      cmds="$cmds
    set newTab to (create tab with profile \"$profile\")
    tell current session of newTab
      write text \"$SSH_CMD $SSH_HOST -t 'tmux select-window -t $s:main 2>/dev/null || true && tmux attach -t $s'\"
    end tell"
    fi
  done

  osascript <<EOF
tell application "iTerm"
  activate
  set newWindow to (create window with profile "$first_profile")
  tell newWindow$cmds
  end tell
end tell
EOF
  echo "✓ Opened ${#sessions[@]} tabs in iTerm2"
}

_terminal_tabs() {
  local sessions=("$@")
  local cmds=""

  # First tab uses the frontmost window
  cmds="do script \"$SSH_CMD $SSH_HOST -t 'tmux select-window -t ${sessions[0]}:main 2>/dev/null || true && tmux attach -t ${sessions[0]}'\""

  for ((i = 1; i < ${#sessions[@]}; i++)); do
    local s="${sessions[$i]}"
    cmds="$cmds
  tell application \"System Events\" to keystroke \"t\" using command down
  delay 0.3
  do script \"$SSH_CMD $SSH_HOST -t 'tmux select-window -t $s:main 2>/dev/null || true && tmux attach -t $s'\" in front window"
  done

  osascript <<EOF
tell application "Terminal"
  activate
  $cmds
end tell
EOF
  echo "✓ Opened ${#sessions[@]} tabs in Terminal.app"
}

# ── macOS: grid ──────────────────────────────────────────────────

mac_grid() {
  local sessions=("$@")

  if [ -d "/Applications/iTerm.app" ]; then
    _iterm_grid "${sessions[@]}"
  else
    # Terminal.app: open separate windows, user tiles manually
    for s in "${sessions[@]}"; do
      osascript -e "tell application \"Terminal\" to do script \"$SSH_CMD $SSH_HOST -t 'tmux select-window -t $s:main 2>/dev/null || true && tmux attach -t $s'\""
    done
    echo "✓ Opened ${#sessions[@]} windows — tile with Rectangle or ⌃⌘+Arrow"
  fi
}

_iterm_grid() {
  local sessions=("$@")
  local n=${#sessions[@]}

  [ "$n" -eq 1 ] && { _iterm_tabs "${sessions[@]}"; return; }

  # iTerm2: create one window, split into grid with per-pane profiles
  local left_n=$(( (n + 1) / 2 ))
  local left=("${sessions[@]:0:$left_n}")
  local right=("${sessions[@]:$left_n}")

  local first_profile=$(_iterm_profile_for "${left[0]}")

  local script="tell application \"iTerm\"
  activate
  set w to (create window with profile \"$first_profile\")
  tell w
    tell current session of current tab
      write text \"$SSH_CMD $SSH_HOST -t 'tmux select-window -t ${left[0]}:main 2>/dev/null || true && tmux attach -t ${left[0]}'\"
"
  # Split right column
  if [ ${#right[@]} -gt 0 ]; then
    local rp=$(_iterm_profile_for "${right[0]}")
    script="$script      set rightPane to (split vertically with profile \"$rp\")
      tell rightPane
        write text \"$SSH_CMD $SSH_HOST -t 'tmux select-window -t ${right[0]}:main 2>/dev/null || true && tmux attach -t ${right[0]}'\"
      end tell
"
  fi

  # Additional rows in right column
  for ((i = 1; i < ${#right[@]}; i++)); do
    local rp=$(_iterm_profile_for "${right[$i]}")
    script="$script      tell rightPane
        set rightPane to (split horizontally with profile \"$rp\")
        write text \"$SSH_CMD $SSH_HOST -t 'tmux select-window -t ${right[$i]}:main 2>/dev/null || true && tmux attach -t ${right[$i]}'\"
      end tell
"
  done

  # Additional rows in left column
  for ((i = 1; i < ${#left[@]}; i++)); do
    local lp=$(_iterm_profile_for "${left[$i]}")
    if [ "$i" -eq 1 ]; then
      script="$script      set leftPane to (split horizontally with profile \"$lp\")
      tell leftPane
        write text \"$SSH_CMD $SSH_HOST -t 'tmux select-window -t ${left[$i]}:main 2>/dev/null || true && tmux attach -t ${left[$i]}'\"
      end tell
"
    else
      script="$script      tell leftPane
        set leftPane to (split horizontally with profile \"$lp\")
        write text \"$SSH_CMD $SSH_HOST -t 'tmux select-window -t ${left[$i]}:main 2>/dev/null || true && tmux attach -t ${left[$i]}'\"
      end tell
"
    fi
  done

  script="$script    end tell
  end tell
end tell"

  osascript -e "$script"
  echo "✓ Opened $n sessions in iTerm2 grid"
}

# ── GSD queue helpers ─────────────────────────────────────────────

# Run a command on the VM with fnm/pyenv in PATH (interactive, with TTY)
_vm_exec() {
  $SSH_CMD "$SSH_HOST" -t "
    export FNM_PATH=\"\$HOME/.local/share/fnm\"
    export PATH=\"\$FNM_PATH:\$HOME/.pyenv/bin:\$HOME/.local/bin:\$HOME/bin:\$PATH\"
    eval \"\$(fnm env 2>/dev/null)\"
    eval \"\$(pyenv init - 2>/dev/null)\"
    $1
  "
}

# Run a command on the VM non-interactively (for data collection)
_vm_batch() {
  $SSH_CMD -o ConnectTimeout=5 -o BatchMode=yes "$SSH_HOST" "
    export FNM_PATH=\"\$HOME/.local/share/fnm\"
    export PATH=\"\$FNM_PATH:\$HOME/.pyenv/bin:\$HOME/.local/bin:\$HOME/bin:\$PATH\"
    eval \"\$(fnm env 2>/dev/null)\"
    eval \"\$(pyenv init - 2>/dev/null)\"
    $1
  "
}

# Scan repos for GSD status. Output: "session|path|gsd_status|phase" per line
# For discussion status, phase may contain multiple comma-separated numbers (e.g. "3,4,5")
_vm_gsd_scan() {
  _vm_batch '
    for s in $(tmux ls -F "#{session_name}" 2>/dev/null); do
      [ "$s" = "gsd-queue" ] && continue
      path=$(tmux display-message -t "$s:shell" -p "#{pane_current_path}" 2>/dev/null || \
             tmux display-message -t "$s:main.0" -p "#{pane_current_path}" 2>/dev/null)
      [ -z "$path" ] && continue
      [ ! -d "$path/.planning" ] && continue

      phases_dir="$path/.planning/phases"
      [ ! -d "$phases_dir" ] && phases_dir=$(find "$path/.planning/milestones" -maxdepth 2 -name "*phases" -type d 2>/dev/null | head -1)
      [ -z "$phases_dir" ] && echo "$s|$path|done|0" && continue

      # Collect ALL undiscussed phases and find first non-complete status
      undiscussed=""
      first_status=""
      first_phase=""

      for phase_dir in $(ls -d "$phases_dir"/*/ 2>/dev/null | sort); do
        phase_num=$(basename "$phase_dir" | grep -oP "^\d+")
        [ -z "$phase_num" ] && continue
        [ -n "$(find "$phase_dir" -name "*VERIFICATION*" 2>/dev/null | head -1)" ] && continue

        ctx=$(find "$phase_dir" -name "*CONTEXT*" 2>/dev/null | head -1)
        pln=$(find "$phase_dir" -name "*PLAN*" 2>/dev/null | head -1)
        smr=$(find "$phase_dir" -name "*SUMMARY*" 2>/dev/null | head -1)

        if [ -z "$ctx" ]; then
          [ -n "$undiscussed" ] && undiscussed="$undiscussed,$phase_num" || undiscussed="$phase_num"
        fi

        # Track first incomplete phase for overall status
        if [ -z "$first_status" ]; then
          if [ -z "$ctx" ]; then
            first_status="discussion"
            first_phase="$phase_num"
          elif [ -z "$pln" ]; then
            first_status="planning"
            first_phase="$phase_num"
          elif [ -z "$smr" ]; then
            first_status="execution"
            first_phase="$phase_num"
          else
            first_status="verify"
            first_phase="$phase_num"
          fi
        fi
      done

      if [ -z "$first_status" ]; then
        # All phases complete — check for pending backlog items
        has_backlog=$(find "$path/.planning/todos/pending" -name "*.md" 2>/dev/null | head -1)
        if [ -n "$has_backlog" ]; then
          backlog_count=$(find "$path/.planning/todos/pending" -name "*.md" 2>/dev/null | wc -l)
          echo "$s|$path|milestone|$backlog_count"
        else
          echo "$s|$path|done|0"
        fi
      elif [ -n "$undiscussed" ]; then
        echo "$s|$path|discussion|$undiscussed"
      else
        echo "$s|$path|$first_status|$first_phase"
      fi
    done
  '
}

# ── dev plan ─────────────────────────────────────────────────────

cmd_plan() {
  echo "Scanning repos for GSD status..."
  echo ""

  local scan
  scan=$(_vm_gsd_scan)
  [ -z "$scan" ] && die "No repos with .planning/ found on $SSH_HOST"

  # Categorise and display
  local needs_milestone=()
  local needs_discussion=()
  local needs_discussion_phases=()

  while IFS='|' read -r session path status phase; do
    [ -z "$session" ] && continue
    case "$status" in
      milestone)
        needs_milestone+=("$session")
        echo "  ★ $session — all phases complete, $phase backlog item(s) — needs new milestone"
        ;;
      discussion)
        needs_discussion+=("$session")
        needs_discussion_phases+=("$phase")
        local phase_display="${phase//,/, }"
        echo "  ● $session — Phases $phase_display: needs discussion"
        ;;
      planning)  echo "  ○ $session — Phase $phase: ready to plan (autonomous)" ;;
      execution) echo "  ○ $session — Phase $phase: ready to execute (autonomous)" ;;
      verify)    echo "  ◇ $session — Phase $phase: needs verification" ;;
      done)      echo "  ✓ $session — all complete, no backlog" ;;
    esac
  done <<< "$scan"

  echo ""

  local total=$((${#needs_milestone[@]} + ${#needs_discussion[@]}))

  if [ "$total" -eq 0 ]; then
    echo "No repos need your input. Run 'dev launch' to start autonomous execution."
    return
  fi

  echo "$total repo(s) need your input."
  echo ""
  read -rp "Start? (y/N): " choice
  [ "$choice" != "y" ] && [ "$choice" != "Y" ] && return

  # ── Step 1: Milestone creation for repos with backlog ──────────
  for session in "${needs_milestone[@]}"; do
    echo ""
    echo "━━━ $session · New Milestone ━━━"
    echo "Claude will auto-run /gsd:new-milestone"
    echo "Select backlog items for the next milestone."
    echo "Ctrl+B D to detach when done."
    echo ""
    read -rp "Press Enter to start..." _

    $SSH_CMD -o BatchMode=yes "$SSH_HOST" "
      tmux send-keys -t '$session:main.0' C-c C-c 2>/dev/null
      sleep 1
      tmux send-keys -t '$session:main.0' 'claude --dangerously-skip-permissions' Enter
      sleep 5
      tmux send-keys -t '$session:main.0' '/gsd:new-milestone' Enter
    "

    if ! $SSH_CMD "$SSH_HOST" -t "tmux select-window -t '$session:main' 2>/dev/null || true && tmux attach -t '$session'"; then
      echo ""
      echo "  SSH disconnected. To resume: ssh cloud-dev -t 'tmux attach -t $session'"
      echo "  Run 'dev plan' again to continue."
    fi

    echo ""
    echo "✓ $session milestone created"
  done

  # If milestones were created, rescan for new discussion phases
  if [ ${#needs_milestone[@]} -gt 0 ]; then
    echo ""
    echo "Rescanning for new discussion phases..."
    scan=$(_vm_gsd_scan)
    needs_discussion=()
    needs_discussion_phases=()

    while IFS='|' read -r session path status phase; do
      [ -z "$session" ] && continue
      if [ "$status" = "discussion" ]; then
        needs_discussion+=("$session")
        needs_discussion_phases+=("$phase")
        local phase_display="${phase//,/, }"
        echo "  ● $session — Phases $phase_display: needs discussion"
      fi
    done <<< "$scan"
    echo ""
  fi

  # ── Step 2: Discussion phases ──────────────────────────────────
  if [ ${#needs_discussion[@]} -eq 0 ]; then
    echo "No phases need discussion. Run 'dev launch' to start autonomous execution."
    read -rp "Launch now? (y/N): " choice
    if [ "$choice" = "y" ] || [ "$choice" = "Y" ]; then
      cmd_launch
    fi
    return
  fi

  for ((i = 0; i < ${#needs_discussion[@]}; i++)); do
    local session="${needs_discussion[$i]}"
    local phases_csv="${needs_discussion_phases[$i]}"

    IFS=',' read -ra phases <<< "$phases_csv"

    for phase in "${phases[@]}"; do
      echo ""
      echo "━━━ $session · Phase $phase ━━━"
      echo "Claude will auto-run /gsd:discuss-phase $phase"
      echo "Answer the questions, then Ctrl+B D to detach when done."
      echo ""
      read -rp "Press Enter to start..." _

      $SSH_CMD -o BatchMode=yes "$SSH_HOST" "
        tmux send-keys -t '$session:main.0' C-c C-c 2>/dev/null
        sleep 1
        tmux send-keys -t '$session:main.0' 'claude --dangerously-skip-permissions' Enter
        sleep 5
        tmux send-keys -t '$session:main.0' '/gsd:discuss-phase $phase' Enter
      "

      if ! $SSH_CMD "$SSH_HOST" -t "tmux select-window -t '$session:main' 2>/dev/null || true && tmux attach -t '$session'"; then
        echo ""
        echo "  SSH disconnected. To resume: ssh cloud-dev -t 'tmux attach -t $session'"
        echo "  Run 'dev plan' again to continue."
      fi

      echo ""
      echo "✓ $session phase $phase discussed"
    done
  done

  echo ""
  echo "All planning complete."
  read -rp "Launch autonomous execution? (y/N): " choice
  if [ "$choice" = "y" ] || [ "$choice" = "Y" ]; then
    cmd_launch
  fi
}

# ── dev launch ───────────────────────────────────────────────────

cmd_launch() {
  # Check if runner is already active
  local running
  running=$($SSH_CMD -o ConnectTimeout=5 -o BatchMode=yes "$SSH_HOST" \
    "tmux has-session -t gsd-queue 2>/dev/null && echo yes || echo no")

  if [ "$running" = "yes" ]; then
    echo "Queue runner is already active."
    read -rp "Restart it? (y/N): " choice
    if [ "$choice" = "y" ] || [ "$choice" = "Y" ]; then
      $SSH_CMD -o BatchMode=yes "$SSH_HOST" "tmux kill-session -t gsd-queue 2>/dev/null" || true
    else
      echo "Use 'dev status' to check progress."
      return
    fi
  fi

  # Always sync runner script to VM (ensures bug fixes are deployed)
  local script_dir
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  if [ -f "$script_dir/gsd-queue-runner.sh" ]; then
    echo "Syncing queue runner to VM..."
    $SSH_CMD -o BatchMode=yes "$SSH_HOST" \
      "mkdir -p ~/bin && cat > ~/bin/gsd-queue-runner.sh && chmod +x ~/bin/gsd-queue-runner.sh" \
      < "$script_dir/gsd-queue-runner.sh"
  else
    die "gsd-queue-runner.sh not found in $script_dir"
  fi

  # Launch the runner in its own tmux session
  $SSH_CMD -o BatchMode=yes "$SSH_HOST" "
    tmux new-session -d -s gsd-queue -x 220 -y 50
    tmux send-keys -t gsd-queue '~/bin/gsd-queue-runner.sh' Enter
  "

  echo ""
  echo "✓ Queue runner started"
  echo ""
  echo "  dev status     check progress"
  echo "  dev priority   change execution order"
}

# ── dev status ───────────────────────────────────────────────────

cmd_status() {
  local state
  state=$($SSH_CMD -o ConnectTimeout=5 -o BatchMode=yes "$SSH_HOST" \
    "cat ~/.gsd-queue-state 2>/dev/null") || true

  if [ -z "$state" ]; then
    echo "No queue state found. Run 'dev launch' first."
    return
  fi

  local runner_alive
  runner_alive=$($SSH_CMD -o ConnectTimeout=5 -o BatchMode=yes "$SSH_HOST" \
    "tmux has-session -t gsd-queue 2>/dev/null && echo yes || echo no")

  echo "GSD Queue"
  echo "════════════════════════════════════════"

  # Parse the state file (simple key=value + pipe-delimited lines)
  local updated="" memory="" wip=""
  local running_count=0 queued_count=0

  while IFS= read -r line; do
    case "$line" in
      updated=*) updated="${line#updated=}" ;;
      memory=*)  memory="${line#memory=}" ;;
      wip_limit=*) wip="${line#wip_limit=}" ;;
      running=*) running_count="${line#running=}" ;;
      *"|"*)
        IFS='|' read -r name status phase <<< "$line"
        case "$status" in
          running)      echo "  ▶ $name  phase $phase" ;;
          queued)       echo "  ○ $name  phase $phase" ;;
          rate-limited) echo "  ⏸ $name  phase $phase  (rate limited)" ;;
          done)         echo "  ✓ $name" ;;
          skipped)      echo "  - $name  phase $phase  (needs human input)" ;;
        esac
        ;;
    esac
  done <<< "$state"

  echo ""
  if [ "$runner_alive" = "yes" ]; then
    echo "  Runner: active  |  WIP: $running_count/$wip  |  Memory: $memory"
  else
    echo "  Runner: stopped"
    if echo "$state" | grep -q "|running|"; then
      echo ""
      echo "  WARNING: Sessions were still running when the runner stopped."
      echo "  The VM may have rebooted. Run 'dev launch' to restart."
    fi
  fi
  echo "  Updated: $updated"
}

# ── dev verify ───────────────────────────────────────────────────

cmd_verify() {
  echo "Scanning for repos with unverified completed phases..."
  echo ""

  local scan
  scan=$(_vm_gsd_scan)
  [ -z "$scan" ] && die "No repos with .planning/ found"

  local needs_verify=()
  local verify_paths=()
  local verify_phases=()

  while IFS='|' read -r session path status phase; do
    [ -z "$session" ] && continue
    if [ "$status" = "verify" ]; then
      needs_verify+=("$session")
      verify_paths+=("$path")
      verify_phases+=("$phase")
    fi
  done <<< "$scan"

  if [ ${#needs_verify[@]} -eq 0 ]; then
    echo "No repos need verification right now."
    return
  fi

  echo "${#needs_verify[@]} repo(s) have work ready for review:"
  echo ""
  for ((i = 0; i < ${#needs_verify[@]}; i++)); do
    echo "  ${needs_verify[$i]} — Phase ${verify_phases[$i]}"
  done
  echo ""
  read -rp "Start verification? (y/N): " choice
  [ "$choice" != "y" ] && [ "$choice" != "Y" ] && return

  for ((i = 0; i < ${#needs_verify[@]}; i++)); do
    local session="${needs_verify[$i]}"
    local path="${verify_paths[$i]}"
    local phase="${verify_phases[$i]}"

    echo ""
    echo "━━━ $session · Phase $phase ━━━"
    echo "Opening Claude Code. Run /gsd:verify-work"
    echo "Exit Claude when done."
    echo ""
    read -rp "Press Enter to open $session..." _

    _vm_exec "cd $path && claude --dangerously-skip-permissions"

    echo ""
    echo "✓ Done with $session"
  done

  echo ""
  echo "All verifications complete."
}

# ── dev priority ─────────────────────────────────────────────────

cmd_priority() {
  if [ $# -gt 0 ]; then
    # Inline mode: dev priority aihub-infra todolisto m2-labs
    local list=""
    for name in "$@"; do
      list+="$name"$'\n'
    done
    printf '%s' "$list" | $SSH_CMD -o BatchMode=yes "$SSH_HOST" "cat > ~/.gsd-priority"
    echo "✓ Priority set:"
    local pos=1
    for name in "$@"; do
      echo "  $pos. $name"
      ((pos++))
    done
  else
    # Show current priority
    echo "Current priority order:"
    echo ""
    local current
    current=$($SSH_CMD -o ConnectTimeout=5 -o BatchMode=yes "$SSH_HOST" \
      "cat ~/.gsd-priority 2>/dev/null") || true
    if [ -z "$current" ]; then
      echo "  (none set — using alphabetical order)"
      echo ""
      echo "Set priority: dev priority <repo1> <repo2> <repo3> ..."
    else
      local pos=1
      while IFS= read -r name; do
        [ -n "$name" ] && echo "  $pos. $name" && ((pos++))
      done <<< "$current"
    fi
  fi
}

# ── dev idea ──────────────────────────────────────────────────────

NTFY_IDEAS_TOPIC="mds-ideas-fb5bf625e6e1a4d2"
IDEA_PIN="4897"

cmd_idea() {
  if [ $# -lt 2 ]; then
    echo "Usage:"
    echo "  dev idea <repo> \"description of the feature\""
    echo "  dev idea <repo> --file requirements.md"
    echo ""
    echo "Or send from your phone via the Ntfy app:"
    echo "  Topic: $NTFY_IDEAS_TOPIC"
    echo "  Title: $IDEA_PIN:<repo>  (e.g. $IDEA_PIN:todolisto)"
    echo "  Message: feature description"
    echo ""
    echo "To clone a new repo from phone:"
    echo "  Title: $IDEA_PIN:newproject"
    echo "  Message: org/repo folder"
    return 1
  fi

  local repo="$1"
  shift

  local title="${IDEA_PIN}:${repo}"

  if [ "$1" = "--file" ] && [ -n "${2:-}" ]; then
    local file="$2"
    [ ! -f "$file" ] && die "File not found: $file"
    local content
    content=$(cat "$file")
    curl -s --max-time 10 \
      -H "Title: $title" \
      --data-raw "$content" \
      "https://ntfy.sh/$NTFY_IDEAS_TOPIC" > /dev/null 2>&1
  else
    local text="$*"
    curl -s --max-time 10 \
      -H "Title: $title" \
      --data-raw "$text" \
      "https://ntfy.sh/$NTFY_IDEAS_TOPIC" > /dev/null 2>&1
  fi

  echo "✓ Idea sent to $repo"
}

# ── dev ideas ─────────────────────────────────────────────────────

cmd_ideas() {
  # Check if listener is running
  local running
  running=$($SSH_CMD -o ConnectTimeout=5 -o BatchMode=yes "$SSH_HOST" \
    "tmux has-session -t gsd-ideas 2>/dev/null && echo yes || echo no")

  case "${1:-}" in
    start)
      if [ "$running" = "yes" ]; then
        echo "Idea listener is already running."
        return
      fi

      # Sync listener script
      local script_dir
      script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
      if [ -f "$script_dir/gsd-idea-listener.sh" ]; then
        $SSH_CMD -o BatchMode=yes "$SSH_HOST" \
          "mkdir -p ~/bin && cat > ~/bin/gsd-idea-listener.sh && chmod +x ~/bin/gsd-idea-listener.sh" \
          < "$script_dir/gsd-idea-listener.sh"
      fi

      $SSH_CMD -o BatchMode=yes "$SSH_HOST" "
        tmux new-session -d -s gsd-ideas -x 220 -y 50
        tmux send-keys -t gsd-ideas '~/bin/gsd-idea-listener.sh' Enter
      "
      echo "✓ Idea listener started"
      echo ""
      echo "Send ideas from your phone:"
      echo "  Ntfy app → publish to topic: $NTFY_IDEAS_TOPIC"
      echo "  Title = repo name, Message = feature description"
      ;;
    stop)
      if [ "$running" = "yes" ]; then
        $SSH_CMD -o BatchMode=yes "$SSH_HOST" "tmux kill-session -t gsd-ideas 2>/dev/null"
        echo "✓ Idea listener stopped"
      else
        echo "Listener not running."
      fi
      ;;
    *)
      if [ "$running" = "yes" ]; then
        echo "Idea listener: running"
      else
        echo "Idea listener: stopped"
      fi
      echo ""
      echo "  dev ideas start    Start the listener"
      echo "  dev ideas stop     Stop the listener"
      echo "  dev idea <repo> \"text\"   Send an idea from your PC"
      echo ""
      echo "From your phone (Ntfy app):"
      echo "  Subscribe to: $NTFY_IDEAS_TOPIC"
      echo "  To send: publish → Title = repo, Message = idea"
      ;;
  esac
}

# ── Main ─────────────────────────────────────────────────────────

main() {
  case "${1:-}" in
    help|-h|--help)
      cmd_help
      ;;
    ls|list)
      cmd_ls
      ;;
    tunnel)
      shift
      cmd_tunnel "$@"
      ;;
    plan)
      cmd_plan
      ;;
    launch)
      cmd_launch
      ;;
    status)
      cmd_status
      ;;
    verify)
      cmd_verify
      ;;
    priority)
      shift
      cmd_priority "$@"
      ;;
    idea)
      shift
      cmd_idea "$@"
      ;;
    ideas)
      shift
      cmd_ideas "$@"
      ;;
    open)
      shift
      local grid=false
      local names=()

      # Parse flags and session names
      while [ $# -gt 0 ]; do
        case "$1" in
          -g|--grid) grid=true ;;
          *)         names+=("$1") ;;
        esac
        shift
      done

      # Fetch session metadata (names + group colors)
      local meta
      meta=$(get_session_meta)
      [ -z "$meta" ] && die "No sessions running on $SSH_HOST"

      # Export meta for helper functions (bash 3.2 compatible — no assoc arrays)
      _SESSION_META="$meta"

      # Resolve which sessions to open (sorted by group order)
      local sessions=()
      if [ ${#names[@]} -gt 0 ]; then
        # Specific names requested — validate then sort
        for name in "${names[@]}"; do
          echo "$meta" | grep -q "^${name}:" || die "Session '$name' not found. Run: dev ls"
        done
        # Build mini-meta for just the requested names and sort
        local mini_meta=""
        for name in "${names[@]}"; do
          mini_meta="${mini_meta}$(echo "$meta" | grep "^${name}:")"$'\n'
        done
        while IFS= read -r sname; do
          [ -n "$sname" ] && sessions+=("$sname")
        done < <(_sort_sessions "$mini_meta")
      else
        while IFS= read -r sname; do
          [ -n "$sname" ] && sessions+=("$sname")
        done < <(_sort_sessions "$meta")
      fi

      echo "Opening ${#sessions[@]} sessions..."
      echo ""

      if $grid; then
        case "$OS" in
          windows) wt_grid "${sessions[@]}" ;;
          macos)   mac_grid "${sessions[@]}" ;;
          *)       die "Grid not supported on this platform. Use: dev <name>" ;;
        esac
      else
        case "$OS" in
          windows) wt_tabs "${sessions[@]}" ;;
          macos)   mac_tabs "${sessions[@]}" ;;
          *)       die "Open not supported on this platform. Use: dev <name>" ;;
        esac
      fi
      ;;
    "")
      # No args — interactive picker
      local sessions=()
      while IFS= read -r s; do
        [ -n "$s" ] && sessions+=("$s")
      done < <(get_sessions)

      [ ${#sessions[@]} -eq 0 ] && die "No sessions running on $SSH_HOST"

      if [ ${#sessions[@]} -eq 1 ]; then
        cmd_attach "${sessions[0]}"
      else
        cmd_pick "${sessions[@]}"
      fi
      ;;
    *)
      # Treat as session name
      cmd_attach "$1"
      ;;
  esac
}

main "$@"
